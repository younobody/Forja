{
  "name": "forja-coach-dashboard",
  "version": "28.6.0",
  "description": "FORJA - Coach Dashboard with comprehensive test coverage",
  "type": "module",
  "scripts": {
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:unit:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:phase1": "node --experimental-vm-modules node_modules/jest/bin/jest.js __tests__/phase1 --coverage",
    "test:phase1:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js __tests__/phase1 --watch",
    "test:e2e": "npx playwright test",
    "test:phase2": "npx playwright test __tests__/phase2",
    "test:e2e:debug": "npx playwright test --debug",
    "test:e2e:headed": "npx playwright test --headed"
  },
  "keywords": [
    "coaching",
    "dashboard",
    "fitness"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.1.5",
    "jest": "^29.7.0"
  }
}
